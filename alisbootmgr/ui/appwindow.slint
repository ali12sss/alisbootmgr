import { Button, VerticalBox, HorizontalBox, ListView, StandardTableView, LineEdit, CheckBox } from "std-widgets.slint";

export struct BootEntry {
    id: string,
    description: string,
    path: string,
    enabled: bool,
}

export component AppWindow inherits Window {
    title: "Rust EFI Boot Manager";
    width: 800px;
    height: 600px;

    in-out property <[BootEntry]> entries: [];
    in-out property <int> selected-index: -1;
    
    // Edit Dialog properties
    property <bool> show-edit-dialog: false;
    property <string> edit-description: "";
    property <string> edit-path: "";
    property <bool> edit-is-new: false;

    callback delete-entry(int);
    callback move-up(int);
    callback move-down(int);
    callback save-entry(string, string, bool); // description, path, is_new

    VerticalBox {
        Text {
            text: "EFI Boot Entries";
            font-size: 24px;
            horizontal-alignment: center;
        }

        // Header
        HorizontalBox {
            max-height: 30px;
            Text { text: "ID"; width: 80px; font-weight: 700; }
            Text { text: "Description"; font-weight: 700; }
            Text { text: "Path"; width: 250px; font-weight: 700; }
            Text { text: "Status"; width: 80px; font-weight: 700; }
        }

        ListView {
            for entry[i] in entries : Rectangle {
                height: 40px;
                background: selected-index == i ? #e0e0e0 : transparent;
                
                TouchArea {
                    clicked => { selected-index = i; }
                    double-clicked => {
                        edit-description = entry.description;
                        edit-path = entry.path;
                        edit-is-new = false;
                        show-edit-dialog = true;
                    }
                }

                HorizontalBox {
                    Text { text: entry.id; width: 80px; vertical-alignment: center; }
                    Text { text: entry.description; vertical-alignment: center; }
                    Text { text: entry.path; width: 250px; vertical-alignment: center; overflow: elide; }
                    Text { text: entry.enabled ? "Active" : "Disabled"; width: 80px; vertical-alignment: center; }
                }
            }
        }

        HorizontalBox {
            alignment: center;
            spacing: 10px;
            Button {
                text: "Move Up";
                enabled: selected-index > 0;
                clicked => { move-up(selected-index); selected-index -= 1; }
            }
            Button {
                text: "Move Down";
                enabled: selected-index >= 0 && selected-index < entries.length - 1;
                clicked => { move-down(selected-index); selected-index += 1; }
            }
            Button {
                text: "Add Entry";
                primary: true;
                clicked => { 
                    edit-description = "New Boot Entry";
                    edit-path = "\\EFI\\BOOT\\BOOTX64.EFI";
                    edit-is-new = true;
                    show-edit-dialog = true;
                }
            }
            Button {
                text: "Edit";
                enabled: selected-index >= 0;
                clicked => {
                    edit-description = entries[selected-index].description;
                    edit-path = entries[selected-index].path;
                    edit-is-new = false;
                    show-edit-dialog = true;
                }
            }
            Button {
                text: "Delete";
                enabled: selected-index >= 0;
                clicked => { delete-entry(selected-index); selected-index = -1; }
            }
        }
    }

    // Modal Edit Overlay
    if show-edit-dialog : Rectangle {
        background: #00000080;
        TouchArea { } // Block clicks to background

        Rectangle {
            width: 500px;
            height: 300px;
            background: white;
            border-radius: 8px;
            border-width: 1px;
            border-color: #ccc;

            VerticalBox {
                padding: 20px;
                Text { 
                    text: edit-is-new ? "Add New Entry" : "Edit Entry";
                    font-size: 18px;
                    font-weight: 700;
                }
                
                Text { text: "Description:"; }
                LineEdit {
                    text: edit-description;
                    edited(t) => { edit-description = t; }
                }

                Text { text: "File Path (on ESP):"; }
                LineEdit {
                    text: edit-path;
                    edited(t) => { edit-path = t; }
                }

                Text { 
                    text: "Example: \\EFI\\arch\\grubx64.efi"; 
                    color: gray; 
                    font-size: 12px;
                }

                HorizontalBox {
                    alignment: end;
                    spacing: 10px;
                    Button {
                        text: "Cancel";
                        clicked => { show-edit-dialog = false; }
                    }
                    Button {
                        text: "Save";
                        primary: true;
                        clicked => { 
                            save-entry(edit-description, edit-path, edit-is-new);
                            show-edit-dialog = false;
                        }
                    }
                }
            }
        }
    }
}
